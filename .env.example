# URL of your n8n instance (no trailing slash)
N8N_BASE_URL=https://n8n.example.com

# API key created at Settings -> n8n API -> Create an API key
N8N_API_KEY=your-key-here

# Verify TLS certificates (set false only for self-signed local dev)
N8N_VERIFY_TLS=true

# Request timeout to n8n in ms
N8N_TIMEOUT_MS=30000

# Public app name shown in the UI
NEXT_PUBLIC_APP_NAME="n8n Dashboard"

# Show Enterprise sections (insights, audit, projects, folders, users,
# variables, source control). Set to "true" to enable.
NEXT_PUBLIC_ENTERPRISE_ENABLED=false

# Enable n8n internal REST API enrichment (folder column on /workflows,
# workflows per folder on /enterprise/folders, folder-aware defaults on
# /backup). Default ON. Set to "false" to disable — the UI then hides
# internal-API-only affordances and the proxy route returns 503.
NEXT_PUBLIC_INTERNAL_API_ENABLED=true

# Internal REST API (n8n /rest/...). Lets the dashboard list workflows by
# folder, show a folder column on /workflows, and auto-suggest folder-aware
# paths on /backup. Requires a regular n8n user (Settings -> Users) — the
# public API key alone is NOT enough.
#
# Leave blank to disable internal-API features. When enabled (default), the
# dashboard logs in once with these credentials, caches the session cookie
# in N8N_INTERNAL_SESSION_FILE for 23h, and reuses it for all subsequent
# internal calls. One shared login for the whole dashboard.
N8N_INTERNAL_EMAIL=
N8N_INTERNAL_PASSWORD=

# Where to cache the internal-API session cookie (plaintext).
# Default: <project-root>/.dashboard-internal-session.json
N8N_INTERNAL_SESSION_FILE=
